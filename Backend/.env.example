# Servidor
PORT=3000
NODE_ENV=production

# Supabase — Conexión a la base de datos (pg pool)
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.tu-project-ref
DB_PASSWORD=tu_password_de_supabase
DB_SSL=true

# Supabase — Storage (usa la Service Role Key, no la anon key)
#
# ⚠️ SEGURIDAD — ALCANCE DE ESTA CLAVE:
# La Service Role Key bypassa Row Level Security y tiene acceso a TODOS
# los buckets, tablas y funciones del proyecto Supabase, no solo a los
# que esta app necesita (buckets "negocios" y "platos").
#
# Recomendaciones obligatorias en el dashboard de Supabase:
#   1. Crea un proyecto Supabase DEDICADO a esta app si comparte org con
#      otros proyectos — nunca reutilices un service key de un proyecto
#      que contenga datos sensibles de otras apps.
#   2. En Storage > Policies, aunque el service key bypassa RLS, define
#      policies igualmente: si en el futuro se migra a anon key + JWT de
#      Supabase, las policies ya estarán listas (defensa en profundidad).
#   3. Restringe el tamaño máximo de archivo y los MIME types permitidos
#      a nivel de bucket en Supabase (además de la validación en código).
#   4. NUNCA imprimas esta clave en logs, mensajes de error verbose, ni
#      la incluyas en respuestas HTTP bajo ninguna circunstancia.
#   5. Si se filtra: rótala inmediatamente desde Settings > API y
#      redeploy del backend con la nueva clave.
#   6. El código solo debe acceder a esta clave a través de db/supabase.js
#      (wrapper con allowlist de buckets) — nunca instancies createClient()
#      en otro archivo.
SUPABASE_URL=https://tu-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# JWT — OBLIGATORIO: mínimo 32 caracteres aleatorios
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REEMPLAZA_ESTO_con_minimo_32_chars_aleatorios_NUNCA_uses_este_valor
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=https://tu-dominio.com/api/auth/google/callback

# Frontend — OBLIGATORIO: URL exacta de tu frontend en producción
FRONTEND_URL=https://tu-dominio.com
